# Copy to `.env` and fill in. Never commit `.env`.
#
# === Public, no credentials needed (paper mode) ===
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# === Live mode (fill in after Polymarket signup in the US) ===
# Polygon RPC for on-chain reads + transactions. Free public RPC is OK for paper;
# use Alchemy/Infura for live (https://alchemy.com/, free tier is enough).
POLYGON_RPC_URL=https://polygon-rpc.com

# CLOB API credentials. Derived from a signed message with the wallet private
# key -- run scripts/derive_clob_keys.py (added before go-live) to generate.
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_API_SECRET=
POLYMARKET_CLOB_API_PASSPHRASE=

# Public address of the Polygon EOA that signs orders (MetaMask address).
# Used only for on-chain position reads here; the private key never leaves your
# machine -- live signing will live in a separate, opt-in module.
POLYMARKET_WALLET_ADDRESS=

# Public address of the Polymarket proxy wallet (deployed on first deposit).
# This is what holds USDC + conditional tokens on-chain. Optional; the runner
# can derive it from the EOA address via Polymarket's factory contract.
POLYMARKET_PROXY_ADDRESS=

# === Optional signal sources ===
# Kalshi API (for cross-venue arbitrage on shared questions).
KALSHI_API_KEY=
KALSHI_API_SECRET=

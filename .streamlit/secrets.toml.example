# Streamlit Cloud secrets template. DO NOT commit a real secrets.toml.
# Paste these into your Streamlit Cloud app's Settings -> Secrets page.

# Public Polygon address that holds your Polymarket funds. Read-only on this side.
POLYMARKET_PROXY_ADDRESS = "0xa8Fd04Ad1A2FF5a57D850A5bE6Fce5D28848C52f"

# Your MetaMask EOA address. Optional; used as a fallback when the proxy
# address isn't set, and as a label in the UI.
POLYMARKET_WALLET_ADDRESS = "0xAc5c1D6657eef3F0EC2b44b5Ab2d5eDF39caf3F9"

# Polygon JSON-RPC. The public endpoint is fine for read-only dashboard use,
# but get rate-limited; Alchemy/Infura URLs work too and don't require a key
# on free tiers.
POLYGON_RPC_URL = "https://polygon-rpc.com"

# Polymarket public APIs (overrideable, defaults are fine).
POLYMARKET_CLOB_URL = "https://clob.polymarket.com"
POLYMARKET_GAMMA_URL = "https://gamma-api.polymarket.com"
POLYMARKET_DATA_API_URL = "https://data-api.polymarket.com"
